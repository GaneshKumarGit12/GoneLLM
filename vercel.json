{
  "version": 2,
  "builds": [
    {
      "src": "gonellm-backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "gonellm-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/gonellm-backend/server.js"
    },
    {
      "source": "/(assets/.*)",
      "destination": "/gonellm-frontend/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/gonellm-frontend/index.html"
    }
  ]
}
