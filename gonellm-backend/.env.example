# MongoDB Atlas Connection String
# Get your free cluster at: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/gonellm?retryWrites=true&w=majority

# JWT Secret (generate a secure random string)
JWT_SECRET=gonellm_secure_jwt_secret_key_change_in_production

# Razorpay Credentials (get from https://razorpay.com)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Server Port
PORT=5000

# LLaMA API Configuration (using OpenAI-compatible API)
# Get API key from: https://llama-api.com or use local LLaMA instance
LLAMA_API_URL=https://api.llama-api.com/chat/completions
LLAMA_API_KEY=your_llama_api_key
